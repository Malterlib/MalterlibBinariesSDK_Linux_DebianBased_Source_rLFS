// Import all roots
Property
{
	MalterlibOnlyRepositoryManagement true
	MalterlibInstallGitHookHelpers false
}

Import "Malterlib/Core/MalterlibRepoOnly.MOptionalHeader"

Repository
{
	!!Repository.Type "Root"
	
	LfsReleaseStore true
}